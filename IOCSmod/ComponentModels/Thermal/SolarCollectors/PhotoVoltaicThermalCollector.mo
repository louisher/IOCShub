        Polygon(
          points={{-89,5},{-77,31},{-54,31},{-65,5},{-89,5}},
          smooth=Smooth.None,
          fillColor={6,13,150},
          fillPattern=FillPattern.Solid,
          pattern=LinePattern.None),
        Polygon(
          points={{-73,37},{-61,63},{-38,63},{-49,37},{-73,37}},
          smooth=Smooth.None,
          fillColor={6,13,150},
          fillPattern=FillPattern.Solid,
          pattern=LinePattern.None),
        Polygon(
          points={{-60,67},{-48,93},{-25,93},{-36,67},{-60,67}},
          smooth=Smooth.None,
          fillColor={6,13,150},
          fillPattern=FillPattern.Solid,
          pattern=LinePattern.None),
        Polygon(
          points={{-24,67},{-12,93},{11,93},{0,67},{-24,67}},
          smooth=Smooth.None,
          fillColor={6,13,150},
          fillPattern=FillPattern.Solid,
          pattern=LinePattern.None),
        Polygon(
          points={{-37,37},{-25,63},{-2,63},{-13,37},{-37,37}},
