        Line(
          points={{-100,0},{-94,0},{-74,0},{-74,-90},{-50,-90},{-50,-20},{-24,-20},
              {-24,-90},{14,-90},{14,-20},{42,-20},{42,-90},{72,-90},{72,-20},{72,
              0},{82,0},{100,0}},
          color={0,128,255},
          thickness=1),
        Line(
          points={{-50,0},{-30,0}},
