		0.0, -3.0034725942531435e-10, 2.3313974400112952e-07, -6.905416136696641e-05, 0.04862465245424163, 14.707347696695033, 450.37869534538197;
		0.0, -5.646623942896544e-11, 4.37664696812956e-08, -1.291963259591843e-05, 0.008165320106028995, 2.550356245290326, 86.23575749830212;
		0.0, -1.5914049287535306e-10, 1.2330094954799982e-07, -3.6319497875918657e-05, 0.020443340169029562, 6.526140654274707, 245.91093921866272;
		0.0, -5.1022366246134355e-11, 3.9545373405228904e-08, -1.1635454041318279e-05, 0.005951276666378445, 1.939293456760153, 80.43926137374477;
		0.0, -4.216611992135244e-11, 3.2704365993560184e-08, -9.618247609583668e-06, 0.0045645222531578095, 1.5189968670344034, 68.31787937628884;
