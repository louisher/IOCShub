	output Real house1_QDay = buildings.Houses.house1.hvac.heatPortEmb[1].Q_flow;
	output Real house1_QNig = buildings.Houses.house1.hvac.heatPortEmb[2].Q_flow;
	output Real house1_mFlowFloHeaDay = buildings.Houses.house1.hvac.floHea1.m_flow;
	output Real house1_mFlowFloHeaNig = buildings.Houses.house1.hvac.floHea2.m_flow;
	
	// hex cooling
	output Real house1_THexCooIn = buildings.Houses.house1.hvac.T_hexCool_primIn.T - 273.15;
	output Real house1_THexCooOut = buildings.Houses.house1.hvac.T_hexCool_primOut.T - 273.15;
	output Real house1_mFlowHexCoo = buildings.Houses.house1.hvac.hexCool.m2_flow;
	output Real house1_QFlowHexCoo = buildings.Houses.house1.hvac.hexCool.Q1_flow;

	//district heating 
	output Real house1_yValSelHea = buildings.Houses.house1.hvac.valSelHea.y;
	output Real house1_yValSelCoo = buildings.Houses.house1.hvac.valSelCoo.y;

	//ventilation
	output Real house1_mAirDayIn = buildings.Houses.house1.bui.DayZone.ports[1].m_flow;
	output Real house1_mAirDayOut = buildings.Houses.house1.bui.DayZone.ports[2].m_flow;
	output Real house1_mAirNigIn = buildings.Houses.house1.bui.NightZone.ports[1].m_flow;
	output Real house1_mAirNigOut = buildings.Houses.house1.bui.NightZone.ports[2].m_flow;
