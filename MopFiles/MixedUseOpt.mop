    output Real n_PV = enerHub.pv.n;

	// Battery 
    output Real Bat_present = if enerHub.hasBat then 1 else 0;
    output Real Bat_cap = enerHub.bat.EBat_max_kWh;
    output Real Bat_P_max = enerHub.bat.P_max;
	output Real Bat_soc = enerHub.bat.SoC ;
	output Real Bat_eff = enerHub.bat.eff ;
	output Real Bat_Pcha = enerHub.bat.PCha ;
	output Real Bat_PDem = enerHub.bat.PDem ;
	output Real Bat_PGrid = enerHub.bat.PGrid ;
	output Real Bat_SOCmax = enerHub.SoC_max;
	output Real Bat_SOCmin = enerHub.SoC_min;

	// STC panels
	output Real A_STC = enerHub.stc.panels.totalArea;
	output Real QStc = enerHub.stc.panels.QTot;

	output Real QStcHex = enerHub.stc.hex.Q2_flow;

	output Real TStcIn = enerHub.stc.senTPanelsIn.T - 273.15; //°C
	output Real TStcOut = enerHub.stc.senTPanelsOut.T - 273.15; //°C
	output Real TStcRegIn = enerHub.stc.senTRegIn.T - 273.15; //°C
	output Real TStcRegOut = enerHub.stc.senTRegOut.T - 273.15; //°C
	output Real TStcHeaIn = enerHub.stc.senTHeaIn.T - 273.15; //°C
	output Real TStcHeaOut = enerHub.stc.senTHeaOut.T - 273.15; //°C
	output Real TStcHexIn = enerHub.stc.senTHexIn.T -273.15; //°C
	output Real TStcHexOut = enerHub.stc.senTHexOut.T -273.15; //°C

	output Real mFlowStc = enerHub.stc.pumPanels.m_flow;
	output Real mFlowStcHex = enerHub.stc.hex.m2_flow;
	output Real mFlowStcHeaIn = enerHub.stc.valSupHea.m_flow;
	output Real mFlowStcHeaOut = enerHub.stc.valRetHea.m_flow;
	output Real mFlowStcRegIn = enerHub.stc.valSupReg.m_flow;
	output Real mFlowStcRegOut = enerHub.stc.valRetReg.m_flow;

	// PVT
	output Real A_PVT = enerHub.pvt.panels.totalArea;
	output Real QPvt = enerHub.pvt.panels.QTot;
	output Real PPvt = enerHub.pvt.P;
	
	output Real QPvtHex = enerHub.pvt.hex.Q2_flow;

	output Real TPvtIn = enerHub.pvt.senTPanelsIn.T - 273.15; //°C
	output Real TPvtOut = enerHub.pvt.senTPanelsOut.T - 273.15; //°C
	output Real TPvtHexIn = enerHub.pvt.senTHexIn.T - 273.15; //°C
	output Real TPvtHexOut = enerHub.pvt.senTHexOut.T - 273.15; //°C
	output Real TPvtRegIn = enerHub.pvt.senTRegIn.T - 273.15; //°C
	output Real TPvtRegOut = enerHub.pvt.senTRegOut.T - 273.15; //°C
	output Real TPvtHeaIn = enerHub.pvt.senTHeaIn.T - 273.15; //°C
	output Real TPvtHeaOut = enerHub.pvt.senTHeaOut.T - 273.15; //°C

	output Real mFlowPvt = enerHub.pvt.pumPanels.m_flow;
	output Real mFlowPvtHex = enerHub.pvt.hex.m2_flow;
	output Real mFlowPvtHeaIn = enerHub.pvt.valSupHea.m_flow;
	output Real mFlowPvtHeaOut = enerHub.pvt.valRetHea.m_flow;
	output Real mFlowPvtRegIn = enerHub.pvt.valSupReg.m_flow;
	output Real mFlowPVtRegOut = enerHub.pvt.valRetReg.m_flow;


	///////////////////////////////////
	// IOCS definitions //
	///////////////////////////////////
	// input data:
	output Real QDem = Q_flow_collector; 	// Demand profile for heat and cold: heat should be positive, cold should be negative
	output Real PDem = P_Net_Houses;							// Demand profile for electricity in the buildings only, offtake should be positive
	output Real QBor = enerHub.GsHp.QBorefield;
	
	// temperature data for COP calculation	
	output Real T_COP_Sup = Ttank; 			// Temperatures should be in °C
	output Real T_COP_Bor = TBorOut; 		// Temperatures should be in °C
	output Real T_COP_Air = TAsHpEvaIn; 	// Temperatures should be in °C

	// overall result data:
	output Real DiscmfHea = house1_DiscmfHeaDay + house1_DiscmfHeaNig +
							house2_DiscmfHeaDay + house2_DiscmfHeaNig +
							house3_DiscmfHeaDay + house3_DiscmfHeaNig +
							office1_DiscmfHeaNor + office1_DiscmfHeaSou + 
							office2_DiscmfHeaNor + office2_DiscmfHeaSou + 
							office3_DiscmfHeaNor + office3_DiscmfHeaSou; // Heating discomort in Kh
	output Real DiscmfCoo = house1_DiscmfCooDay + house1_DiscmfCooNig +
							house2_DiscmfCooDay + house2_DiscmfCooNig +
							house3_DiscmfCooDay + house3_DiscmfCooNig +
							office1_DiscmfCooNor + office1_DiscmfCooSou + 
							office2_DiscmfCooNor + office2_DiscmfCooSou + 
							office3_DiscmfCooNor + office3_DiscmfCooSou; // Cooling discomfort in Kh

	output Real ElecUse = TotalPower; // Overall energy use of the entire district (buildings + energy hub), offtake should be positive
	
	///////////////////////////////////
	////////  INVESTMENT COSTS ////////
	///////////////////////////////////
	
	parameter input Real GsHpSize(free=true, min=0.1, max=40.0, start=21.8, nominal=1/(21.1*inv_scaler/(8760*3600))); // nominal: 1/(GsHp_inv*cost_to_per_second_scaler*inv_scaler)
	output Real GsHp_rel_inv_cost= enerHub.GsHp.inv_hp.annInvCost "Relative annual investement cost of GsHp";
	output Real GsHp_inv_cost_ann = GsHp_rel_inv_cost * GsHpSize "Annualized investment cost of GsHp";

	parameter input Real BorSize(free=true, min=50, max=300, start=110.0, nominal=1/(2.39*enerHub.borFieDat.conDat.nBor*inv_scaler*8760/(8760*3600))); 
    parameter input Real QpExtOpt(free=true, min=-60000, max=0, start=0, nominal=1);
    parameter input Real QpInjOpt(free=true, min=0, max=60000, start=0, nominal=1);
	output Real Bor_rel_inv_cost = enerHub.GsHp.inv_bor.annInvCost "Relative annual investement cost of Borefield";
	output Real Bor_inv_cost_ann = Bor_rel_inv_cost * BorSize "Annualized investment cost of Borefield";

	parameter input Real AsHpSize(free=true, min=0.1, max=40.0, start=0.1, nominal=1/(76.1*inv_scaler/(8760*3600))); // nominal: 1/(AsHp_inv*cost_to_per_second_scaler*inv_scaler)
	output Real AsHp_rel_inv_cost= enerHub.AsHp.inv.annInvCost "Relative annual investement cost of AsHp";
	output Real AsHp_inv_cost_ann = AsHp_rel_inv_cost * AsHpSize "Annualized investment cost of AsHp";

	parameter input Real AsChiSize(free=true, min=0.1, max=40.0, start=13.6, nominal=1/(33.8*inv_scaler/(8760*3600))); // nominal: 1/(AsHp_inv*cost_to_per_second_scaler*inv_scaler)
	output Real AsChi_rel_inv_cost= enerHub.AsChi.inv.annInvCost "Relative annual investement cost of AsChi";
	output Real AsChi_inv_cost_ann = AsChi_rel_inv_cost * AsChiSize "Annualized investment cost of AsChi";

	parameter input Real TankSize(free=true, min=0.1, max=10, start=1.2, nominal=1/(84.5*inv_scaler/(8760*3600)));
	output Real Tank_rel_inv_cost= enerHub.tan.inv.annInvCost "Relative annual investement cost of Tank";
	output Real Tank_inv_cost_ann = Tank_rel_inv_cost * TankSize "Annualized investment cost of Tank";

	parameter input Real STCSize(free=true, min=0.1, max=100, start=0.1, nominal=1/(33.8*inv_scaler/(8760*3600)));
	output Real Stc_rel_inv_cost = enerHub.stc.inv.annInvCost "Relative annual investement cost of STC";
	output Real Stc_inv_cost_ann = Stc_rel_inv_cost * STCSize "Annualized investment cost of STC";

	parameter input Real PVTSize(free=true, min=0.1, max=100, start=0.1, nominal=1/(42.3*inv_scaler/(8760*3600)));
	output Real Pvt_rel_inv_cost = enerHub.pvt.inv.annInvCost "Relative annual investement cost of PVT";
	output Real Pvt_inv_cost_ann = Pvt_rel_inv_cost * PVTSize "Annualized investment cost of PVT";

	parameter input Real PVSize(free=true, min=0.1, max=100, start=40.0, nominal=1/(16.9*inv_scaler/(8760*3600))); // nominal: 1/(AsHp_inv*cost_to_per_second_scaler*inv_scaler)
	output Real PV_rel_inv_cost= enerHub.pv.inv.annInvCost "Relative annual investement cost of PV";
	output Real PV_inv_cost_ann = PV_rel_inv_cost * PVSize "Annualized investment cost of PV";

	parameter input Real BatSize(free=true, min=0.1, max=50, start=0.1, nominal=1/(53.3*inv_scaler/(8760*3600)));
	output Real Bat_rel_inv_cost = enerHub.bat.inv.annInvCost "Relative annual investement cost of Bat";
	output Real Bat_inv_cost_ann = Bat_rel_inv_cost * BatSize "Annualized investment cost of Bat";

	output Real Total_annualized_investment = GsHp_inv_cost_ann + Bor_inv_cost_ann + AsHp_inv_cost_ann + AsChi_inv_cost_ann + PV_inv_cost_ann + Bat_inv_cost_ann + Stc_inv_cost_ann + Pvt_inv_cost_ann + Tank_inv_cost_ann;
	output Real inv_cost_per_second = Total_annualized_investment/(8760*3600); // euro per second

	///////////////////////////////////
	// Objective function definition //
	///////////////////////////////////

	/// Investment ///
	parameter Real inv_scaler = 36000000;
	output Real ObjInv = inv_scaler*inv_cost_per_second;

	/// Electricity ///
	output Real TotalPower = P_Net_enerHub + P_Net_Houses;

	output Real tariff_scaler = 36000000;
	output Real p_offtake = priceSim.p_elec_fix_offtake/(3600*1e6); // €/J
	output Real p_offtakeSca = p_offtake * tariff_scaler;
	output Real p_inj = priceSim.p_elec_fix_inj/(3600*1e6); // €/J
	output Real p_injSca = p_inj * tariff_scaler;
	output Real b = 50; // transition parameter
	output Real smoothPrice = p_injSca + (p_offtakeSca - p_injSca) * 0.5 *(1 + TotalPower / (sqrt(TotalPower^2 + b^2)) );

	output Real ObjIntElecCost = TotalPower*smoothPrice;

	// Battery //
	output Real weight_bat = 100000;
	output Real ObjBatMax = weight_bat*max(0, Bat_soc - Bat_SOCmax)^2;
	output Real ObjBatMin = weight_bat*max(0, Bat_SOCmin - Bat_soc)^2;
	output Real ObjIntBat = ObjBatMax + ObjBatMin;

	// Supply temperature	
	output Real TSupMax = 60;
	output Real ObjIntTSupMax = 10000*max(0, Ttank - TSupMax)^2;
	output Real TSupMin = 5;
	output Real ObjIntTSupMin = 10000*max(0, TSupMin - Ttank)^2;

	// Borefield temperature
	output Real TBorMin_degC = enerHub.TBorMin - 273.15;
	output Real TBorMax = 25;
	output Real TBorAvg = (TBorIn + TBorOut)/2;
	output Real ObjIntTBorMin = 10000*max(0, TBorMin_degC - TBorAvg)^2;
	output Real ObjIntTBorMax = 10000*max(0, TBorAvg - TBorMax)^2;

	// Borefield peak
	output Real ObjIntBorPeak = 0.1*(max(0, QpExtOpt - QBorIn_L3)^2 + max(0, -QpInjOpt + QBorIn_L3)^2);
	
	// Borefield temperature
	output Real termObj = 1000000*(sum(max(0, delTfInjOut[i]-7)^2 for i in 1:enerHub.GsHp.borefield.groTemResFin.nStepsYear) + sum(max(0, -10 - delTfExtOut[i])^2 for i in 1:enerHub.GsHp.borefield.groTemResFin.nStepsYear));

	// Minimum floor heating temperature
	output Real RH = sim.relHum*100;
	parameter Real weight_fh = 100;
	//real Tmin=17 (increased it a bit and lowered the weighting factor)
	output Real TFloHea_min = 17.5; 
    output Real ObjIntFloHeaMin1 = weight_fh*(max(0, TFloHea_min - house1_TFloHea1)^2 + max(0, TFloHea_min - house1_TFloHea2)^2);
    output Real ObjIntFloHeaMin2 = weight_fh*(max(0, TFloHea_min - house2_TFloHea1)^2 + max(0, TFloHea_min - house2_TFloHea2)^2);
    output Real ObjIntFloHeaMin3 = weight_fh*(max(0, TFloHea_min - house3_TFloHea1)^2 + max(0, TFloHea_min - house3_TFloHea2)^2);
    output Real ObjIntFloHeaMinOff1 = weight_fh*(max(0, TFloHea_min - office1_TFloHea1)^2 + max(0, TFloHea_min - office1_TFloHea2)^2);
    output Real ObjIntFloHeaMinOff2 = weight_fh*(max(0, TFloHea_min - office2_TFloHea1)^2 + max(0, TFloHea_min - office2_TFloHea2)^2);
    output Real ObjIntFloHeaMinOff3 = weight_fh*(max(0, TFloHea_min - office3_TFloHea1)^2 + max(0, TFloHea_min - office3_TFloHea2)^2);
    output Real ObjIntFloHeaMin = ObjIntFloHeaMin1 + ObjIntFloHeaMin2 + ObjIntFloHeaMin3 + ObjIntFloHeaMinOff1 + ObjIntFloHeaMinOff2 + ObjIntFloHeaMinOff3;


	// Comfort
	output Real weight_hea = 10000;
	output Real weight_coo = 10000;
	output Real ObjIntComfSHea=weight_hea*(house1_DiscmfHeaDay^2 + house1_DiscmfHeaNig^2 +
											house2_DiscmfHeaDay^2 + house2_DiscmfHeaNig^2 +
											house3_DiscmfHeaDay^2 + house3_DiscmfHeaNig^2 +
											office1_DiscmfHeaNor^2 + office1_DiscmfHeaSou^2 +
											office2_DiscmfHeaNor^2 + office2_DiscmfHeaSou^2 +
											office3_DiscmfHeaNor^2 + office3_DiscmfHeaSou^2);
	output Real ObjIntComfSCoo=weight_coo*(house1_DiscmfCooDay^2 + house1_DiscmfCooNig^2 +
											house2_DiscmfCooDay^2 + house2_DiscmfCooNig^2 +
											house3_DiscmfCooDay^2 + house3_DiscmfCooNig^2 +
											office1_DiscmfCooNor^2 + office1_DiscmfCooSou^2 +
											office2_DiscmfCooNor^2 + office2_DiscmfCooSou^2 +
											office3_DiscmfCooNor^2 + office3_DiscmfCooSou^2);

	/// Overall objective ///
	output Real ObjInt = ObjInv + ObjIntElecCost + ObjIntComfSCoo + ObjIntComfSHea + ObjIntBat + ObjIntTSupMax + ObjIntTSupMin + ObjIntTBorMin + ObjIntTBorMax + ObjIntFloHeaMin + ObjIntBorPeak;

	

	///////////////////////////////////
	// Borefield Constants //
	///////////////////////////////////
	parameter Real Kappa_agg_Constants[19, 7] = [
		0.0, -1.6566909187111748e-10, 1.301285594853147e-07, -3.393647194607709e-05, 0.45799796325279846, 37.4956932866931, 10.83208068030122;
		0.0, 1.2889057695923222e-09, -9.486883798971263e-07, 0.00022385690536574126, 0.8108927766207467, 156.1509243894794, -66.75332488029115;
		0.0, -2.8080535774317904e-10, 1.7044657972792037e-07, -3.1096572299274745e-05, 0.2691521492573401, 55.72750417242158, 22.110899265127763;
		0.0, 1.4128807916335659e-12, 4.09173786717465e-10, -2.935605693536463e-07, 0.020843905945225793, 4.432549522411837, 1.5622569874895282;
		0.0, 1.4540771334905746e-12, -5.59219571698788e-10, -4.186441210466511e-09, 0.020308451609293728, 4.31189123104058, 1.9487259402739459;
