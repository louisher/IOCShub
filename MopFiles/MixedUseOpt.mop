		0.0, -6.153769940239365e-11, 4.360397698021148e-08, -1.1918882079797239e-05, 0.5670106054172441, 118.49359867268632, 115.59837791519057;
		0.0, -2.2185848066430293e-10, 1.613171840846423e-07, -4.328350023101688e-05, 0.9551040905165981, 197.76470995776432, 301.490004236116;
		0.0, -7.043277828023437e-10, 5.192582204127941e-07, -0.0001403758503127265, 1.4719533379711858, 292.6405417326006, 726.7110066726146;
		0.0, -3.2467776651220526e-09, 2.445185064442469e-06, -0.0006798025755506268, 3.8433070458623564, 613.9690994413853, 2518.2419243945733;
		0.0, -7.138836574359206e-10, 5.557398161382599e-07, -0.00016211136252350576, 0.565899835319955, 59.2311966531421, 399.0361446376047;
		0.0, -1.7305247458414883e-10, 1.3830996325095294e-07, -4.221037881565113e-05, 0.09134892944965355, 6.203472844337907, 70.45296712039398;
		0.0, -1.4467913305380645e-09, 1.1354078564764042e-06, -0.00034217665194295586, 0.37701805291396573, 17.583280770975925, 368.06001739745227;
		0.0, -4.844678694857646e-10, 3.760902595580612e-07, -0.00011062048558575488, 0.04984505529705752, 1.5053043163769941, 71.87434768244897;
		0.0, -1.1398802881843065e-07, 9.245729813040375e-05, -0.028344604470278596, 5.458756575082013, 51.639265720327955, 12700.975193198952;
		0.0, 1.276007455677062e-09, -8.941808871450512e-07, 0.00023176504579238433, -0.009179960556879349, 0.6867873632397039, -32.7835137849553;
		0.0, 1.6227059824221292e-07, -0.00012229170195599505, 0.03468379447105517, -1.041028910466905, 126.93125942473189, -3372.4449270955597;
		0.0, 2.985409508009569e-08, -2.290068557308649e-05, 0.006524143326856185, -0.16549808776065922, 23.505897836381486, 300.6848679025804;
		0.0, 3.045923514231395e-09, -2.3098085504471616e-06, 0.0006180637535219534, -0.015243691373184294, 3.923132289974739, 398.2716422149988
	];
	parameter Real Gamma_Constants[7] = {0.0, -3.221705926052306e-09, 2.4128631691600358e-06, 0.00020759540107958714, 0.05035218534710397, 7.700938128956949, -40.880685870158686};
	parameter Real Xi_Ext_Constants[7] = {0.0, -3.5758185703198925e-10, 2.667276077906494e-07, 2.6290377211251178e-05, 0.031889788102217306, 0.8755620488929156, -0.9437394765932136};
	parameter Real Xi_Inj_Constants[7] = {0.0, -3.5758185703198925e-10, 2.667276077906494e-07, 2.6290377211251178e-05, 0.031889788102217306, 0.8755620488929156, -0.9437394765932136};
	parameter Real Kappa_L3_Constants[480, 7] = [
		0.0, -7.445806320467395e-12, 5.516395961823381e-09, -1.4994366379604956e-06, 0.07637832800653307, 1.4157956044518676, 1.1205139029793894;
