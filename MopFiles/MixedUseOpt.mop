		0.0, -2.824558500320629e-12, 2.2550126973078916e-09, -6.911464247116954e-07, 0.0011517329940144213, 0.24893188241913125, 3.6196491996115774;
		0.0, -1.1246127262207851e-08, 8.93150195612305e-06, -0.0027268435196041944, 3.8331132167650526, 894.7496276111094, 15134.554644119908;
		0.0, -2.8240533867563068e-11, 2.227183052416782e-08, -6.751365830785846e-06, 0.008128706991430605, 2.0331265670722947, 39.348382449784786;
		0.0, -5.878447797347407e-10, 4.6111749742387113e-07, -0.00013884097729997033, 0.14354992818899923, 38.02630305939254, 835.8765166332704;
		0.0, -3.2671327987321155e-10, 2.5495709543412667e-07, -7.622786915442848e-05, 0.06909712896585885, 19.297746809417962, 474.8399761373888;
