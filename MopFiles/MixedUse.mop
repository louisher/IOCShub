	input Real uOff3(free=true, start=1, min=-1, max=1, nominal= 1/7659);

	
	////////////////////////////////
	// Demand Output variables    //
	////////////////////////////////
	
	//Overall //
	output Real P_Net_Houses = buildings.P; // Positive value means net offtake
	output Real P_pumDh = buildings.pumNetwork.P;

	//Collector
	output Modelica.Units.NonSI.Temperature_degC TSup_collector = Modelica.Units.Conversions.to_degC(buildings.Houses.collector.TSup) "";
	output Modelica.Units.NonSI.Temperature_degC TRet_collector = Modelica.Units.Conversions.to_degC(buildings.Houses.collector.TRet) "";
