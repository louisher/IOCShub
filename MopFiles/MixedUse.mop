	output Real QPvtHex = enerHub.pvt.hex.Q2_flow;

	output Real TPvtIn = enerHub.pvt.senTPanelsIn.T - 273.15; //°C
	output Real TPvtOut = enerHub.pvt.senTPanelsOut.T - 273.15; //°C
	output Real TPvtHexIn = enerHub.pvt.senTHexIn.T - 273.15; //°C
	output Real TPvtHexOut = enerHub.pvt.senTHexOut.T - 273.15; //°C
