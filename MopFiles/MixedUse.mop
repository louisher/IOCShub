	output Real TPvtHeaOut = enerHub.pvt.senTHeaOut.T - 273.15; //°C

	output Real mFlowPvt = enerHub.pvt.pumPanels.m_flow;
	output Real mFlowPvtHex = enerHub.pvt.hex.m2_flow;
	output Real mFlowPvtHeaIn = enerHub.pvt.valSupHea.m_flow;
	output Real mFlowPvtHeaOut = enerHub.pvt.valRetHea.m_flow;
	output Real mFlowPvtRegIn = enerHub.pvt.valSupReg.m_flow;
	output Real mFlowPVtRegOut = enerHub.pvt.valRetReg.m_flow;

	///////////////////////////////////
	// IOCS definitions //
	///////////////////////////////////
	// input data:
	output Real QDem = Q_flow_collector; 	// Demand profile for heat and cold: heat should be positive, cold should be negative
	output Real PDem = P_Net_Houses;							// Demand profile for electricity in the buildings only, offtake should be positive
	output Real QBor = enerHub.GsHp.QBorefield;
	
	// temperature data for COP calculation	
	output Real T_COP_Sup = Ttank; 			// Temperatures should be in °C
	output Real T_COP_Bor = TBorOut; 		// Temperatures should be in °C
	output Real T_COP_Air = TAsHpEvaIn; 	// Temperatures should be in °C

	// overall result data:
	output Real DiscmfHea = house1_DiscmfHeaDay + house1_DiscmfHeaNig +
							house2_DiscmfHeaDay + house2_DiscmfHeaNig +
							house3_DiscmfHeaDay + house3_DiscmfHeaNig +
							office1_DiscmfHeaNor + office1_DiscmfHeaSou + 
							office2_DiscmfHeaNor + office2_DiscmfHeaSou + 
							office3_DiscmfHeaNor + office3_DiscmfHeaSou; // Heating discomort in Kh
	output Real DiscmfCoo = house1_DiscmfCooDay + house1_DiscmfCooNig +
							house2_DiscmfCooDay + house2_DiscmfCooNig +
							house3_DiscmfCooDay + house3_DiscmfCooNig +
							office1_DiscmfCooNor + office1_DiscmfCooSou + 
							office2_DiscmfCooNor + office2_DiscmfCooSou + 
							office3_DiscmfCooNor + office3_DiscmfCooSou; // Cooling discomfort in Kh

	output Real ElecUse = TotalPower; // Overall energy use of the entire district (buildings + energy hub), offtake should be positive


	///////////////////////////////////
	// Objective function definition //
	///////////////////////////////////

	/// Electricity ///
	output Real TotalPower = P_Net_enerHub + P_Net_Houses;
	
	output Real tariff_scaler = 36000000;
	output Real p_offtake = priceSim.p_elec_fix_offtake/(3600*1e6); // €/J
	output Real p_offtakeSca = p_offtake * tariff_scaler;
	output Real p_inj = priceSim.p_elec_fix_inj/(3600*1e6); // €/J
	output Real p_injSca = p_inj * tariff_scaler;
	output Real b = 50; // transition parameter
	output Real smoothPrice = p_injSca + (p_offtakeSca - p_injSca) * 0.5 *(1 + TotalPower / (sqrt(TotalPower^2 + b^2)) );

	output Real ObjIntElecCost = TotalPower*smoothPrice;

	// Battery //
	output Real weight_bat = 100000;
	output Real ObjBatMax = weight_bat*max(0, Bat_soc - Bat_SOCmax)^2;
	output Real ObjBatMin = weight_bat*max(0, Bat_SOCmin - Bat_soc)^2;
	output Real ObjIntBat = ObjBatMax + ObjBatMin;
	
	// Supply temperature	
	output Real TSupMax = 60;
	output Real ObjIntTSupMax = 10000*max(0, Ttank - TSupMax)^2;
	output Real TSupMin = 5;
	output Real ObjIntTSupMin = 10000*max(0, TSupMin - Ttank)^2;

	// Borefield temperature
	output Real TBorMin_degC = enerHub.TBorMin - 273.15;
	output Real TBorMax = 17.1;
	output Real TBorAvg = (TBorIn + TBorOut)/2;
	output Real ObjIntTBorMin = 10000*max(0, TBorMin_degC - TBorAvg)^2;
	output Real ObjIntTBorMax = 10000*max(0, TBorAvg - TBorMax)^2;

	// Minimum floor heating temperature
	output Real RH = sim.relHum*100;
	parameter Real weight_fh = 100;
	//real Tmin=17 (increased it a bit and lowered the weighting factor)
	output Real TFloHea_min = 17.5; 
    output Real ObjIntFloHeaMin1 = weight_fh*(max(0, TFloHea_min - house1_TFloHea1)^2 + max(0, TFloHea_min - house1_TFloHea2)^2);
    output Real ObjIntFloHeaMin2 = weight_fh*(max(0, TFloHea_min - house2_TFloHea1)^2 + max(0, TFloHea_min - house2_TFloHea2)^2);
    output Real ObjIntFloHeaMin3 = weight_fh*(max(0, TFloHea_min - house3_TFloHea1)^2 + max(0, TFloHea_min - house3_TFloHea2)^2);
    output Real ObjIntFloHeaMinOff1 = weight_fh*(max(0, TFloHea_min - office1_TFloHea1)^2 + max(0, TFloHea_min - office1_TFloHea2)^2);
    output Real ObjIntFloHeaMinOff2 = weight_fh*(max(0, TFloHea_min - office2_TFloHea1)^2 + max(0, TFloHea_min - office2_TFloHea2)^2);
    output Real ObjIntFloHeaMinOff3 = weight_fh*(max(0, TFloHea_min - office3_TFloHea1)^2 + max(0, TFloHea_min - office3_TFloHea2)^2);
    output Real ObjIntFloHeaMin = ObjIntFloHeaMin1 + ObjIntFloHeaMin2 + ObjIntFloHeaMin3 + ObjIntFloHeaMinOff1 + ObjIntFloHeaMinOff2 + ObjIntFloHeaMinOff3;


	// Comfort
	output Real weight_hea = 10000;
	output Real weight_coo = 10000;
	output Real ObjIntComfSHea=weight_hea*(house1_DiscmfHeaDay^2 + house1_DiscmfHeaNig^2 +
											house2_DiscmfHeaDay^2 + house2_DiscmfHeaNig^2 +
											house3_DiscmfHeaDay^2 + house3_DiscmfHeaNig^2 +
											office1_DiscmfHeaNor^2 + office1_DiscmfHeaSou^2 +
											office2_DiscmfHeaNor^2 + office2_DiscmfHeaSou^2 +
											office3_DiscmfHeaNor^2 + office3_DiscmfHeaSou^2);
	output Real ObjIntComfSCoo=weight_coo*(house1_DiscmfCooDay^2 + house1_DiscmfCooNig^2 +
											house2_DiscmfCooDay^2 + house2_DiscmfCooNig^2 +
											house3_DiscmfCooDay^2 + house3_DiscmfCooNig^2 +
											office1_DiscmfCooNor^2 + office1_DiscmfCooSou^2 +
											office2_DiscmfCooNor^2 + office2_DiscmfCooSou^2 +
											office3_DiscmfCooNor^2 + office3_DiscmfCooSou^2);

	/// Overall objective ///
	output Real ObjInt = ObjIntElecCost + ObjIntComfSCoo + ObjIntComfSHea + ObjIntBat + ObjIntTSupMax + ObjIntTSupMin + ObjIntTBorMin + ObjIntTBorMax + ObjIntFloHeaMin;


end MixedUse;