	output Real QCon_ASCHI = enerHub.AsChi.AsChi.Chi.con.Q_flow;
	output Real QEva_ASCHI = enerHub.AsChi.AsChi.QEva; // !!! Positive value
	output Real EER_ASHP = enerHub.AsChi.AsChi.EER;

	output Real TAsChiEvaIn = enerHub.AsChi.senTAsChiEvaIn.T - 273.15; //°C
	output Real TAsChiEvaOut = enerHub.AsChi.senTAsChiEvaOut.T - 273.15; //°C
	output Real TAsChiConIn = enerHub.AsChi.AsChi.Chi.TConIn.T - 273.15; //°C
	output Real TAsChiConOut = enerHub.AsChi.AsChi.Chi.TConOut.T - 273.15; //°C

	output Real mFlowAsChiEva = enerHub.AsChi.AsChi.Chi.m1_flow;

	// Tank
	output Real Ttank = enerHub.tan.vol.T - 273.15; //°C
	output Real Vtank = enerHub.tan.VTan;

