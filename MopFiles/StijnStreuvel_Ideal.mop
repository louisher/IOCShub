	output Real DiscmfTFloHea_nr_3_Badkamer = max(0, TCore_embeddedPipe_1_zone_Huis_nr_3_Badkamer - TFloHeaMax);
	output Real DiscmfTFloHea_nr_3_Inkom = max(0, TCore_embeddedPipe_1_zone_Huis_nr_3_Inkom - TFloHeaMax);
	output Real DiscmfTFloHea_nr_3_Leefruimte = max(0, TCore_embeddedPipe_1_zone_Huis_nr_3_Leefruimte - TFloHeaMax);
	output Real DiscmfTFloHea_nr_3_Slaapkamer = max(0, TCore_embeddedPipe_1_zone_Huis_nr_3_Slaapkamer - TFloHeaMax);
	output Real DiscmfTFloHea_nr_5_Badkamer = max(0, TCore_embeddedPipe_1_zone_Huis_nr_5_Badkamer - TFloHeaMax);
	output Real DiscmfTFloHea_nr_5_Inkom = max(0, TCore_embeddedPipe_1_zone_Huis_nr_5_Inkom - TFloHeaMax);
	output Real DiscmfTFloHea_nr_5_Leefruimte = max(0, TCore_embeddedPipe_1_zone_Huis_nr_5_Leefruimte - TFloHeaMax);
	output Real DiscmfTFloHea_nr_5_Slaapkamer = max(0, TCore_embeddedPipe_1_zone_Huis_nr_5_Slaapkamer - TFloHeaMax);
	output Real DiscmfTFloHea_nr_7_Badkamer = max(0, TCore_embeddedPipe_1_zone_Huis_nr_7_Badkamer - TFloHeaMax);
	output Real DiscmfTFloHea_nr_7_Inkom = max(0, TCore_embeddedPipe_1_zone_Huis_nr_7_Inkom - TFloHeaMax);
	output Real DiscmfTFloHea_nr_7_Leefruimte = max(0, TCore_embeddedPipe_1_zone_Huis_nr_7_Leefruimte - TFloHeaMax);
	output Real DiscmfTFloHea_nr_7_Slaapkamer = max(0, TCore_embeddedPipe_1_zone_Huis_nr_7_Slaapkamer - TFloHeaMax);
	output Real DiscmfTFloHea_nr_9_Badkamer = max(0, TCore_embeddedPipe_1_zone_Huis_nr_9_Badkamer - TFloHeaMax);
	output Real DiscmfTFloHea_nr_9_Leefruimte = max(0, TCore_embeddedPipe_1_zone_Huis_nr_9_Leefruimte - TFloHeaMax);
	output Real DiscmfTFloHea_nr_9_Slaapkamer = max(0, TCore_embeddedPipe_1_zone_Huis_nr_9_Slaapkamer - TFloHeaMax);

	// overall result data:
	output Real DiscmfHea = DiscmfHea_Huis_3_Leefruimte +
				DiscmfHea_Huis_5_Leefruimte +
				DiscmfHea_Huis_7_Leefruimte +
				DiscmfHea_Huis_9_Leefruimte +
				DiscmfHea_Huis_11_Leefruimte +
				DiscmfHea_Huis_13_Leefruimte +
				DiscmfHea_Huis_15_Leefruimte +
				DiscmfHea_Huis_17_Leefruimte +
				DiscmfHea_Huis_19_Leefruimte +
				DiscmfHea_Huis_21_Leefruimte +
				DiscmfHea_Huis_23_Leefruimte +
				DiscmfHea_Huis_25_Leefruimte +
				DiscmfHea_Huis_27_Leefruimte +
				DiscmfHea_Huis_29_Leefruimte +
				DiscmfHea_Huis_31_Leefruimte; // Heating discomort in Kh
	output Real DiscmfCoo = DiscmfCoo_Huis_3_LeefruimteCoo +
				DiscmfCoo_Huis_5_LeefruimteCoo +
				DiscmfCoo_Huis_7_LeefruimteCoo +
				DiscmfCoo_Huis_9_LeefruimteCoo +
				DiscmfCoo_Huis_11_LeefruimteCoo +
				DiscmfCoo_Huis_13_LeefruimteCoo +
				DiscmfCoo_Huis_15_LeefruimteCoo +
				DiscmfCoo_Huis_17_LeefruimteCoo +
				DiscmfCoo_Huis_19_LeefruimteCoo +
				DiscmfCoo_Huis_21_LeefruimteCoo +
				DiscmfCoo_Huis_23_LeefruimteCoo +
				DiscmfCoo_Huis_25_LeefruimteCoo +
				DiscmfCoo_Huis_27_LeefruimteCoo +
				DiscmfCoo_Huis_29_LeefruimteCoo +
				DiscmfCoo_Huis_31_LeefruimteCoo; // Cooling discomfort in Kh

	output Real ObjIntTFloHeaMax = DiscmfTFloHea_nr_11_Badkamer^2 + 
									DiscmfTFloHea_nr_11_Leefruimte^2 + DiscmfTFloHea_nr_11_Slaapkamer^2 + 
									DiscmfTFloHea_nr_13_Badkamer^2 + DiscmfTFloHea_nr_13_Leefruimte^2 + 
									DiscmfTFloHea_nr_13_Slaapkamer^2 + DiscmfTFloHea_nr_15_Badkamer^2 + 
									DiscmfTFloHea_nr_15_Leefruimte^2 + DiscmfTFloHea_nr_15_Slaapkamer^2 + 
									DiscmfTFloHea_nr_17_Badkamer^2 + DiscmfTFloHea_nr_17_Inkom^2 + 
									DiscmfTFloHea_nr_17_Leefruimte^2 + DiscmfTFloHea_nr_17_Slaapkamer^2 + 
									DiscmfTFloHea_nr_19_Badkamer^2 + DiscmfTFloHea_nr_19_Inkom^2 + 
									DiscmfTFloHea_nr_19_Leefruimte^2 + DiscmfTFloHea_nr_19_Slaapkamer^2 + 
									DiscmfTFloHea_nr_21_Badkamer^2 + DiscmfTFloHea_nr_21_Inkom^2 + 
									DiscmfTFloHea_nr_21_Leefruimte^2 + DiscmfTFloHea_nr_21_Slaapkamer^2 + 
									DiscmfTFloHea_nr_23_Badkamer^2 + DiscmfTFloHea_nr_23_Leefruimte^2 + 
									DiscmfTFloHea_nr_23_Slaapkamer^2 + DiscmfTFloHea_nr_25_Badkamer^2 + 
									DiscmfTFloHea_nr_25_Leefruimte^2 + DiscmfTFloHea_nr_25_Slaapkamer^2 + 
									DiscmfTFloHea_nr_27_Badkamer^2 + DiscmfTFloHea_nr_27_Leefruimte^2 + 
									DiscmfTFloHea_nr_27_Slaapkamer^2 + DiscmfTFloHea_nr_29_Badkamer^2 + 
									DiscmfTFloHea_nr_29_Leefruimte^2 + DiscmfTFloHea_nr_29_Slaapkamer^2 + 
									DiscmfTFloHea_nr_31_Badkamer^2 + DiscmfTFloHea_nr_31_Inkom^2 + 
									DiscmfTFloHea_nr_31_Leefruimte^2 + DiscmfTFloHea_nr_31_Slaapkamer^2 + 
									DiscmfTFloHea_nr_3_Badkamer^2 + DiscmfTFloHea_nr_3_Inkom^2 + 
									DiscmfTFloHea_nr_3_Leefruimte^2 + DiscmfTFloHea_nr_3_Slaapkamer^2 + 
									DiscmfTFloHea_nr_5_Badkamer^2 + DiscmfTFloHea_nr_5_Inkom^2 + 
									DiscmfTFloHea_nr_5_Leefruimte^2 + DiscmfTFloHea_nr_5_Slaapkamer^2 + 
									DiscmfTFloHea_nr_7_Badkamer^2 + DiscmfTFloHea_nr_7_Inkom^2 + 
									DiscmfTFloHea_nr_7_Leefruimte^2 + DiscmfTFloHea_nr_7_Slaapkamer^2 + 
									DiscmfTFloHea_nr_9_Badkamer^2 + DiscmfTFloHea_nr_9_Leefruimte^2 + 
									DiscmfTFloHea_nr_9_Slaapkamer^2;


	///////////////////////////////////
	// Objective function definition //
	///////////////////////////////////
	output Real COPproxy_nr_3 = 5 - 0.103*(TSup_nr_3 - 313.15);
	output Real COPproxy_nr_5 = 5 - 0.103*(TSup_nr_5 - 313.15);
	output Real COPproxy_nr_7 = 5 - 0.103*(TSup_nr_7 - 313.15);
	output Real COPproxy_nr_9 = 5 - 0.103*(TSup_nr_9 - 313.15);
	output Real COPproxy_nr_11 = 5 - 0.103*(TSup_nr_11 - 313.15);
	output Real COPproxy_nr_13 = 5 - 0.103*(TSup_nr_13 - 313.15);
	output Real COPproxy_nr_15 = 5 - 0.103*(TSup_nr_15 - 313.15);
	output Real COPproxy_nr_17 = 5 - 0.103*(TSup_nr_17 - 313.15);
	output Real COPproxy_nr_19 = 5 - 0.103*(TSup_nr_19 - 313.15);
	output Real COPproxy_nr_21 = 5 - 0.103*(TSup_nr_21 - 313.15);
	output Real COPproxy_nr_23 = 5 - 0.103*(TSup_nr_23 - 313.15);
	output Real COPproxy_nr_25 = 5 - 0.103*(TSup_nr_25 - 313.15);
	output Real COPproxy_nr_27 = 5 - 0.103*(TSup_nr_27 - 313.15);
	output Real COPproxy_nr_29 = 5 - 0.103*(TSup_nr_29 - 313.15);
	output Real COPproxy_nr_31 = 5 - 0.103*(TSup_nr_31 - 313.15);

	output Real Phc_nr_3 = QH3/COPproxy_nr_3 + QC3/4;
	output Real Phc_nr_5 = QH5/COPproxy_nr_5 + QC5/4;
	output Real Phc_nr_7 = QH7/COPproxy_nr_7 + QC7/4;
	output Real Phc_nr_9 = QH9/COPproxy_nr_9 + QC9/4;
	output Real Phc_nr_11 = QH11/COPproxy_nr_11 + QC11/4;
	output Real Phc_nr_13 = QH13/COPproxy_nr_13 + QC13/4;
	output Real Phc_nr_15 = QH15/COPproxy_nr_15 + QC15/4;
	output Real Phc_nr_17 = QH17/COPproxy_nr_17 + QC17/4;
	output Real Phc_nr_19 = QH19/COPproxy_nr_19 + QC19/4;
	output Real Phc_nr_21 = QH21/COPproxy_nr_21 + QC21/4;
	output Real Phc_nr_23 = QH23/COPproxy_nr_23 + QC23/4;
	output Real Phc_nr_25 = QH25/COPproxy_nr_25 + QC25/4;
	output Real Phc_nr_27 = QH27/COPproxy_nr_27 + QC27/4;
	output Real Phc_nr_29 = QH29/COPproxy_nr_29 + QC29/4;
	output Real Phc_nr_31 = QH31/COPproxy_nr_31 + QC31/4;

	output Real Phc_tot = Phc_nr_3 + Phc_nr_5 + Phc_nr_7 + Phc_nr_9 + Phc_nr_11 + Phc_nr_13 + Phc_nr_15 + Phc_nr_17 + Phc_nr_19 + Phc_nr_21 + Phc_nr_23 + Phc_nr_25 + Phc_nr_27 + Phc_nr_29 + Phc_nr_31;


	/// Comfort ///
	output Real TSetHea = 21;
	output Real TSetCoo = 26;
	output Real weight_hea = 10000;
	output Real weight_coo = 10000;
	output Real ObjIntComfSHea=weight_hea*(
				DiscmfHea_Huis_3_Leefruimte^2 +
				DiscmfHea_Huis_5_Leefruimte^2 +
				DiscmfHea_Huis_7_Leefruimte^2 +
				DiscmfHea_Huis_9_Leefruimte^2 +
				DiscmfHea_Huis_11_Leefruimte^2 +
				DiscmfHea_Huis_13_Leefruimte^2 +
				DiscmfHea_Huis_15_Leefruimte^2 +
				DiscmfHea_Huis_17_Leefruimte^2 +
				DiscmfHea_Huis_19_Leefruimte^2 +
				DiscmfHea_Huis_21_Leefruimte^2 +
				DiscmfHea_Huis_23_Leefruimte^2 +
				DiscmfHea_Huis_25_Leefruimte^2 +
				DiscmfHea_Huis_27_Leefruimte^2 +
				DiscmfHea_Huis_29_Leefruimte^2 +
				DiscmfHea_Huis_31_Leefruimte^2);
	output Real ObjIntComfSCoo=weight_coo*(
				DiscmfCoo_Huis_3_LeefruimteCoo^2 +
				DiscmfCoo_Huis_5_LeefruimteCoo^2 +
				DiscmfCoo_Huis_7_LeefruimteCoo^2 +
				DiscmfCoo_Huis_9_LeefruimteCoo^2 +
				DiscmfCoo_Huis_11_LeefruimteCoo^2 +
				DiscmfCoo_Huis_13_LeefruimteCoo^2 +
				DiscmfCoo_Huis_15_LeefruimteCoo^2 +
				DiscmfCoo_Huis_17_LeefruimteCoo^2 +
				DiscmfCoo_Huis_19_LeefruimteCoo^2 +
				DiscmfCoo_Huis_21_LeefruimteCoo^2 +
				DiscmfCoo_Huis_23_LeefruimteCoo^2 +
				DiscmfCoo_Huis_25_LeefruimteCoo^2 +
				DiscmfCoo_Huis_27_LeefruimteCoo^2 +
				DiscmfCoo_Huis_29_LeefruimteCoo^2 +
				DiscmfCoo_Huis_31_LeefruimteCoo^2);
	
	/// Overall objective ///
	output Real ObjInt = Phc_tot + ObjIntComfSCoo + ObjIntComfSHea;

end StijnStreuvel_Ideal;