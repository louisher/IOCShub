optimization StijnStreuvel_Ideal(tolerance=1e-1, objectiveIntegrand=ObjInt, startTime=0, finalTime=startTime+1, timeStep=3600, intervalLengths="8760*1", truncationDelta=1e-2)
	extends IOCSmod.Demand.PeakLoadSimulations.StijnS_Opt(addDummyEquation=false,
									sim.filNam=Modelica.Utilities.Files.loadResource("modelica://IOCSmod/Resources/weatherdata//Brussels-City_XMY2021-2040_ssp245_MAR-BCC_SWDbased.mos"),
