	output Real DiscmfCoo_Huis_23_SlaapkamerCoo = max(0, -TSetCoo + T_zone__Huis_nr_23_Slaapkamer);
	output Real DiscmfCoo_Huis_23_LeefruimteCoo = max(0, -TSetCoo + T_zone__Huis_nr_23_Leefruimte);
	output Real DiscmfCoo_Huis_23_BadkamerCoo = max(0, -TSetCoo + T_zone__Huis_nr_23_Badkamer);
	output Real DiscmfCoo_Huis_25_SlaapkamerCoo = max(0, -TSetCoo + T_zone__Huis_nr_25_Slaapkamer);
	output Real DiscmfCoo_Huis_25_LeefruimteCoo = max(0, -TSetCoo + T_zone__Huis_nr_25_Leefruimte);
	output Real DiscmfCoo_Huis_25_BadkamerCoo = max(0, -TSetCoo + T_zone__Huis_nr_25_Badkamer);
	output Real DiscmfCoo_Huis_27_SlaapkamerCoo = max(0, -TSetCoo + T_zone__Huis_nr_27_Slaapkamer);
	output Real DiscmfCoo_Huis_27_LeefruimteCoo = max(0, -TSetCoo + T_zone__Huis_nr_27_Leefruimte);
	output Real DiscmfCoo_Huis_27_BadkamerCoo = max(0, -TSetCoo + T_zone__Huis_nr_27_Badkamer);
	output Real DiscmfCoo_Huis_29_SlaapkamerCoo = max(0, -TSetCoo + T_zone__Huis_nr_29_Slaapkamer);
	output Real DiscmfCoo_Huis_29_LeefruimteCoo = max(0, -TSetCoo + T_zone__Huis_nr_29_Leefruimte);
	output Real DiscmfCoo_Huis_29_BadkamerCoo = max(0, -TSetCoo + T_zone__Huis_nr_29_Badkamer);
	output Real DiscmfCoo_Huis_31_SlaapkamerCoo = max(0, -TSetCoo + T_zone__Huis_nr_31_Slaapkamer);
	output Real DiscmfCoo_Huis_31_LeefruimteCoo = max(0, -TSetCoo + T_zone__Huis_nr_31_Leefruimte);
	output Real DiscmfCoo_Huis_31_InkomCoo = max(0, -TSetCoo + T_zone__Huis_nr_31_Inkom);
	output Real DiscmfCoo_Huis_31_BadkamerCoo = max(0, -TSetCoo + T_zone__Huis_nr_31_Badkamer);

	///////////////////////////////////
	// IOCS definitions //
	///////////////////////////////////
	// input data:
	output Real QDem = Q_flow_collector__Heating_collector; 	// Demand profile for heat and cold: heat should be positive, cold should be negative
	output Real PDem = P_Net_Houses;							// Demand profile for electricity in the buildings only, offtake should be positive
	output Real QBor = enerHub.GsHp.QBorefield;
	
	// temperature data for COP calculation	
	output Real T_COP_Sup = Ttank; 			// Temperatures should be in °C
	output Real T_COP_Bor = TBorOut; 		// Temperatures should be in °C
	output Real T_COP_Air = TAsHpEvaIn; 	// Temperatures should be in °C

	// overall result data:
	output Real DiscmfHea = DiscmfHea_Huis_3_Leefruimte +
				DiscmfHea_Huis_5_Leefruimte +
				DiscmfHea_Huis_7_Leefruimte +
				DiscmfHea_Huis_9_Leefruimte +
				DiscmfHea_Huis_11_Leefruimte +
				DiscmfHea_Huis_13_Leefruimte +
				DiscmfHea_Huis_15_Leefruimte +
				DiscmfHea_Huis_17_Leefruimte +
				DiscmfHea_Huis_19_Leefruimte +
				DiscmfHea_Huis_21_Leefruimte +
				DiscmfHea_Huis_23_Leefruimte +
				DiscmfHea_Huis_25_Leefruimte +
				DiscmfHea_Huis_27_Leefruimte +
				DiscmfHea_Huis_29_Leefruimte +
				DiscmfHea_Huis_31_Leefruimte; // Heating discomort in Kh
	output Real DiscmfCoo = DiscmfCoo_Huis_3_LeefruimteCoo +
				DiscmfCoo_Huis_5_LeefruimteCoo +
				DiscmfCoo_Huis_7_LeefruimteCoo +
				DiscmfCoo_Huis_9_LeefruimteCoo +
				DiscmfCoo_Huis_11_LeefruimteCoo +
				DiscmfCoo_Huis_13_LeefruimteCoo +
				DiscmfCoo_Huis_15_LeefruimteCoo +
				DiscmfCoo_Huis_17_LeefruimteCoo +
				DiscmfCoo_Huis_19_LeefruimteCoo +
				DiscmfCoo_Huis_21_LeefruimteCoo +
				DiscmfCoo_Huis_23_LeefruimteCoo +
				DiscmfCoo_Huis_25_LeefruimteCoo +
				DiscmfCoo_Huis_27_LeefruimteCoo +
				DiscmfCoo_Huis_29_LeefruimteCoo +
				DiscmfCoo_Huis_31_LeefruimteCoo; // Cooling discomfort in Kh
	output Real ElecUse = TotalPower; // Overall energy use of the entire district (buildings + energy hub), offtake should be positive	

	///////////////////////////////////
	// Objective function definition //
	///////////////////////////////////

	/// Electricity ///
	output Real TotalPower = P_Net_enerHub + P_Net_Houses;

	output Real tariff_scaler = 36000000;
	output Real p_offtake = priceSim.p_elec_fix_offtake/(3600*1e6); // €/J
	output Real p_offtakeSca = p_offtake * tariff_scaler;
	output Real p_inj = priceSim.p_elec_fix_inj/(3600*1e6); // €/J
	output Real p_injSca = p_inj * tariff_scaler;
	output Real b = 50; // transition parameter
	output Real smoothPrice = p_injSca + (p_offtakeSca - p_injSca) * 0.5 *(1 + TotalPower / (sqrt(TotalPower^2 + b^2)) );

	output Real ObjIntElecCost = TotalPower*smoothPrice;

	// Battery //
	output Real weight_bat = 100000;
	output Real ObjBatMax = weight_bat*max(0, Bat_soc - Bat_SOCmax)^2;
	output Real ObjBatMin = weight_bat*max(0, Bat_SOCmin - Bat_soc)^2;
	output Real ObjIntBat = ObjBatMax + ObjBatMin;
	
	// Supply temperature	
	output Real TSupMax = 50;
	output Real ObjIntTSupMax = 1000*max(0, Ttank - TSupMax)^2;
	output Real TSupMin = 5;
	output Real ObjIntTSupMin = 1000*max(0, TSupMin - Ttank)^2;

	// Borefield temperature
	output Real TBorMin_degC = enerHub.TBorMin - 273.15;
	output Real TBorMax = 20.0;
	output Real TBorAvg = (TBorIn + TBorOut)/2;
	output Real ObjIntTBorMin = 10000*max(0, TBorMin_degC - TBorAvg)^2;
	output Real ObjIntTBorMax = 10000*max(0, TBorAvg - TBorMax)^2;

	/// Comfort ///
	output Real TSetHea = 21;
	output Real TSetCoo = 26;
	output Real weight_hea = 10000;
	output Real weight_coo = 10000;
	output Real ObjIntComfSHea=weight_hea*(
				DiscmfHea_Huis_3_Leefruimte^2 +
				DiscmfHea_Huis_5_Leefruimte^2 +
				DiscmfHea_Huis_7_Leefruimte^2 +
				DiscmfHea_Huis_9_Leefruimte^2 +
				DiscmfHea_Huis_11_Leefruimte^2 +
				DiscmfHea_Huis_13_Leefruimte^2 +
				DiscmfHea_Huis_15_Leefruimte^2 +
				DiscmfHea_Huis_17_Leefruimte^2 +
				DiscmfHea_Huis_19_Leefruimte^2 +
				DiscmfHea_Huis_21_Leefruimte^2 +
				DiscmfHea_Huis_23_Leefruimte^2 +
				DiscmfHea_Huis_25_Leefruimte^2 +
				DiscmfHea_Huis_27_Leefruimte^2 +
				DiscmfHea_Huis_29_Leefruimte^2 +
				DiscmfHea_Huis_31_Leefruimte^2);
	output Real ObjIntComfSCoo=weight_coo*(
				DiscmfCoo_Huis_3_LeefruimteCoo^2 +
				DiscmfCoo_Huis_5_LeefruimteCoo^2 +
				DiscmfCoo_Huis_7_LeefruimteCoo^2 +
				DiscmfCoo_Huis_9_LeefruimteCoo^2 +
				DiscmfCoo_Huis_11_LeefruimteCoo^2 +
				DiscmfCoo_Huis_13_LeefruimteCoo^2 +
				DiscmfCoo_Huis_15_LeefruimteCoo^2 +
				DiscmfCoo_Huis_17_LeefruimteCoo^2 +
				DiscmfCoo_Huis_19_LeefruimteCoo^2 +
				DiscmfCoo_Huis_21_LeefruimteCoo^2 +
				DiscmfCoo_Huis_23_LeefruimteCoo^2 +
				DiscmfCoo_Huis_25_LeefruimteCoo^2 +
				DiscmfCoo_Huis_27_LeefruimteCoo^2 +
				DiscmfCoo_Huis_29_LeefruimteCoo^2 +
				DiscmfCoo_Huis_31_LeefruimteCoo^2);
	
	/// Overall objective ///
	output Real ObjInt = ObjIntElecCost + ObjIntComfSCoo + ObjIntComfSHea + ObjIntBat + ObjIntTSupMax + ObjIntTSupMin + ObjIntTBorMin + ObjIntTBorMax;

end StijnStreuvel;